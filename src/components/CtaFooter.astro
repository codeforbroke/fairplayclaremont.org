---
const shareUrl = 'https://fairplayclaremont.org';
const shareText =
  'Girls softball in Claremont has no field with lights AND a fence. Claremont City Council needs to fix this.';
const enc = encodeURIComponent;

const shares = [
  {
    name: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${enc(shareUrl)}`,
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  {
    name: 'X',
    href: `https://twitter.com/intent/tweet?text=${enc(shareText)}&url=${enc(shareUrl)}`,
    path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  },
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(shareUrl)}`,
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  },
];
---

<!-- CTA Band -->
<section id="action" class="bg-forest py-16 px-6 scroll-mt-16">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">

    <div>
      <h2 class="font-display text-2xl md:text-3xl font-semibold text-white leading-snug max-w-md">
        Add your name. Make the City Council listen.
      </h2>
      <p class="text-forest-pale text-base mt-3 max-w-sm leading-relaxed">
        Ch. 11.08 can only be repealed after a public hearing before the City Council.
        Your signature shows up.
      </p>
    </div>

    <div class="flex flex-col gap-4 flex-shrink-0 sm:items-end">
      <a
        href="https://www.ipetitions.com/petition/fair-and-equal-girls-in-claremont"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-white text-forest font-bold text-base px-6 py-3 rounded-md hover:bg-forest-ghost transition-colors duration-150"
      >
        Sign the petition<span class="sr-only"> (opens in new tab)</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
      <div class="flex items-center gap-2.5" role="group" aria-labelledby="share-label">
        <span id="share-label" class="text-forest-pale text-sm font-medium mr-1">
          Share with your neighbors
        </span>
        {shares.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Share on ${s.name}`}
            class="inline-flex items-center justify-center w-9 h-9 rounded-full text-white/90 hover:text-white hover:bg-white/10 transition-colors duration-150"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path d={s.path} />
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="border-t border-gray-100 bg-white px-6 py-8">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <p class="text-xs text-gray-600">
        Fair Play Claremont &nbsp;·&nbsp; Not affiliated with the City of Claremont
      </p>
      <p class="text-xs text-gray-600 mt-1">
        Website donated by
        <a
          href="https://codeforbroke.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-600 hover:text-gray-900 underline transition-colors"
        >Code For Broke, Inc.<span class="sr-only"> (opens in new tab)</span></a>
      </p>
    </div>
    <nav aria-label="Footer links">
      <ul class="flex flex-wrap gap-4 sm:gap-6">
        <li>
          <a
            href="https://ecode360.com/43830587"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block py-1 text-xs text-gray-600 hover:text-gray-900 transition-colors"
          >
            Ordinance 11.08<span class="sr-only"> (opens in new tab)</span>
          </a>
        </li>
        <li>
          <a
            href="https://www.ipetitions.com/petition/fair-and-equal-girls-in-claremont"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block py-1 text-xs text-gray-600 hover:text-gray-900 transition-colors"
          >
            Sign the petition<span class="sr-only"> (opens in new tab)</span>
          </a>
        </li>
        <li>
          <a
            href="https://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202320240AB2404"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block py-1 text-xs text-gray-600 hover:text-gray-900 transition-colors"
          >
            AB 2404 text<span class="sr-only"> (opens in new tab)</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
