---
const stats = [
  { value: '0',     label: "Girls' fields\nwith lights AND fence" },
  { value: '0',     label: "Girls' fields\nthat lock" },
  { value: '4',     label: "Sundays/year girls\nget at La Puerta" },
  { value: '∞',     label: "Sundays boys can\nuse College Park", valueLabel: 'Unlimited' },
];
---

<div class="bg-forest-deep">
  <div class="max-w-6xl mx-auto px-6 py-5 grid grid-cols-2 md:grid-cols-4 gap-6">
    {stats.map(s => (
      <div class="text-center">
        <div class="font-display text-3xl md:text-4xl font-bold text-softball" aria-label={s.valueLabel}>
          <span aria-hidden={s.valueLabel ? 'true' : undefined}>{s.value}</span>
        </div>
        <div class="text-xs text-forest-light mt-1 leading-snug whitespace-pre-line">{s.label}</div>
      </div>
    ))}
  </div>
</div>
